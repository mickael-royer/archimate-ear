      <child xsi:type="archimate:DiagramObject" id="id-f3a01ff2b0324f22bbf29f862436c516" targetConnections="id-191d8e1d5c8b41d2b7f1c733c12ce799 id-32f7fcea30214dc69d7a473fab2750d2 id-bc188235adc64892b5a315e84f78225d" fontColor="#fbfbfb" fillColor="#696b3b" archimateElement="id-5527f8d0b7054ce9adf15c2be9ddeb91">
        <bounds x="552" y="288" width="120" height="55"/>
