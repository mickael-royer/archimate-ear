      <child xsi:type="archimate:DiagramObject" id="id-4cc93a516a994dcfb82e805acb5bee60" targetConnections="id-a220fdd0d24f4b96815ec37b868d5a59" font="1|Lucida Grande|12.0|1|COCOA|1|LucidaGrande-Bold" fontColor="#f6f4f5" fillColor="#696b3b" imagePath="images/_iY5RcMdjEe-GXIRjuNkhSA.png" archimateElement="id-4e007959cd554c56809c72cd6120feb8">
